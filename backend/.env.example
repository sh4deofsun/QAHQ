# Required
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# Database — SQLite for local dev, PostgreSQL in production
DATABASE_URL=sqlite:///./data/qahq.db
# DATABASE_URL=postgresql+psycopg2://qahq:password@localhost:5432/qahq

# MCP (leave empty to disable the /mcp endpoint)
MCP_API_KEY=

# LDAP (leave LDAP_SERVER_URL empty to disable)
LDAP_SERVER_URL=
LDAP_USE_SSL=false
LDAP_BIND_DN=cn=admin,dc=example,dc=com
LDAP_BIND_PASSWORD=
LDAP_SEARCH_BASE=dc=example,dc=com
LDAP_USER_FILTER=(uid={username})
LDAP_DEFAULT_ROLE=qa
